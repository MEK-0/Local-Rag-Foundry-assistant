# Copy this file to .env and fill in the values you need.
# .env is gitignored — never commit real secrets.

# --- Mode switch -------------------------------------------------------
# "local" = Foundry Local + SQLite, fully offline, no Azure needed.
# "cloud" = Azure AI Search + Azure OpenAI.
MODE=local

# --- App -----------------------------------------------------------------
APP_NAME=local-rag-assistant
TOP_K=3
CHUNK_SIZE_TOKENS=200
CHUNK_OVERLAP_TOKENS=40

# --- Foundry Local (local mode) ------------------------------------------
FOUNDRY_CHAT_MODEL=phi-3.5-mini
FOUNDRY_EMBEDDING_MODEL=qwen3-0.6b

# --- Azure AI Search (cloud mode) ----------------------------------------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=rag-index

# --- Azure Blob Storage (cloud mode, document sync) ----------------------
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=rag-documents

# --- Azure OpenAI (cloud mode) --------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Application Insights (optional, both modes) --------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Public demo safety (cloud mode, if deployed publicly) ----------------
RATE_LIMIT_PER_MINUTE=5